# AIWear Docker Compose 环境变量模板
# 使用方法：复制成本地 .env，然后只在服务器里填写真实值。
# 注意：.env 不能提交到 Git，也不要发到聊天里。

# PostgreSQL
POSTGRES_DB=aiwear
POSTGRES_USER=aiwear
POSTGRES_PASSWORD=please-change-postgres-password

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET=please-change-this-to-a-long-random-secret
JWT_EXPIRE_HOURS=2

# 邮箱验证码
EMAIL_ENABLED=true
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USERNAME=your-email@qq.com
SMTP_PASSWORD=your-email-authorization-code
SMTP_FROM_EMAIL=your-email@qq.com
VERIFICATION_CODE_EXPIRE_SECONDS=300

# 文件存储：部署到服务器时建议使用 oss
STORAGE_BACKEND=oss
UPLOAD_DIR=/app/uploads
LOCAL_FILE_BASE_URL=/uploads

# 本地 CLIP 模型在服务器上的宿主机路径
# 如果服务器暂时没有模型，可以先不填；上传图片仍可成功，但向量索引会失败。
CLIP_MODEL_HOST_DIR=/opt/aiwear/models/clip-vit-base-patch16
CLIP_MODEL_DIR=/app/models/clip-vit-base-patch16
IMAGE_SEARCH_MIN_SCORE=0.25

# DashScope
DASHSCOPE_API_KEY=sk-your-dashscope-api-key

# 阿里云 OSS
OSS_ENDPOINT=https://oss-cn-beijing.aliyuncs.com
OSS_BUCKET=your-bucket-name
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret
OSS_BASE_URL=https://your-bucket-name.oss-cn-beijing.aliyuncs.com
