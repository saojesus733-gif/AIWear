# AIWear 环境变量模板
# 使用方法：复制本文件为 .env，然后填写真实配置。
# 注意：.env 里会包含密钥，不能提交到 Git。

# 数据库
# 本地 PostgreSQL 示例：
DATABASE_URL=postgresql+psycopg2://aiwear:123456@127.0.0.1:5432/aiwear
# SQLite 备用示例：
# DATABASE_URL=sqlite:///./aiwear.db

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=please-change-this-to-a-random-secret
JWT_EXPIRE_HOURS=2

# 邮箱验证码
EMAIL_ENABLED=false
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USERNAME=your-email@qq.com
SMTP_PASSWORD=your-email-authorization-code
SMTP_FROM_EMAIL=your-email@qq.com
VERIFICATION_CODE_EXPIRE_SECONDS=300

# 文件存储：local 或 oss
STORAGE_BACKEND=local
UPLOAD_DIR=./uploads
LOCAL_FILE_BASE_URL=/uploads

# 本地 CLIP 模型路径
CLIP_MODEL_DIR=./models/clip-vit-base-patch16
IMAGE_SEARCH_MIN_SCORE=0.25

# DashScope
DASHSCOPE_API_KEY=sk-your-dashscope-api-key

# 阿里云 OSS
OSS_ENDPOINT=https://oss-cn-beijing.aliyuncs.com
OSS_BUCKET=your-bucket-name
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret
OSS_BASE_URL=https://your-bucket-name.oss-cn-beijing.aliyuncs.com
